# Copiar a .env y rellenar con los valores del proyecto de Supabase
# (Dashboard → Settings → API).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Parche temporal: link estático (sin suscripción automática). Mejor no usarlo.
# VITE_MERCADOPAGO_PAYMENT_LINK=https://mpago.la/xxxxx

# Solo para scripts de admin (npm run upload:images). NUNCA con prefijo VITE_.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Edge Functions (secrets en Supabase) ──
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# MERCADOPAGO_SANDBOX=false
# Clave secreta del webhook (Dashboard MP → Webhooks → firma secreta).
# Sin ella, mp-webhook NO verifica la firma (solo advierte en logs).
# MERCADOPAGO_WEBHOOK_SECRET=
